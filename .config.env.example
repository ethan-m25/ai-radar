# AI Radar — config template
# Copy this file to .config.env and fill in real values.
# .config.env is .gitignored — never commit secrets.

# Discord webhook URL for #ai-radar channel
# Get it: Discord → channel settings → Integrations → Webhooks → New Webhook → Copy URL
AIRADAR_DISCORD_WEBHOOK="https://discord.com/api/webhooks/REPLACE_ME"

# Email recipient (where the daily digest goes)
AIRADAR_EMAIL_TO="jim.liumingjing@gmail.com"

# Email sender (must match the Gmail account whose app password you use)
AIRADAR_EMAIL_FROM="jim.liumingjing@gmail.com"

# Gmail App Password (NOT your regular Gmail password)
# Get it: https://myaccount.google.com/apppasswords (requires 2FA enabled)
# Generate a 16-character password labeled "AI Radar"
AIRADAR_GMAIL_APP_PASSWORD="REPLACE_ME_16_chars"
